# ====================================
# Telegram Configuration (Required)
# ====================================

# Telegram Bot Token
# Get it from @BotFather in Telegram: https://t.me/BotFather
TELEGRAM_TOKEN=your_bot_token_here

# Your Telegram Chat ID (User ID)
# Get it from @userinfobot in Telegram: https://t.me/userinfobot
# This is required for security - only you can use the bot
TELEGRAM_CHAT_ID=your_chat_id_here

# ====================================
# Optional: LLM API Keys
# ====================================

# Groq API Key (for voice messages transcription)
# Get it at: https://console.groq.com/keys
# Provides free Whisper API for voice message processing
# GROQ_API_KEY=gsk_your_key_here

# Google Gemini API Key (for AI features integration)
# Get it at: https://ai.google.dev/
# GEMINI_API_KEY=your_gemini_key_here

# ====================================
# Optional: Public bot mode
# ====================================
# BOT_PUBLIC=true

# Optional: Additional allowed user IDs
# ALLOWED_CHAT_IDS=123456789,987654321
